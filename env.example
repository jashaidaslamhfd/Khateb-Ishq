# LLM (Urdu poetry — 70b recommended for quality couplets)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# YouTube OAuth — IMPORTANT: mint these while logged into the Google account
# that OWNS the Urdu channel (it is a different account from the science
# channels; a wrong-account token uploads to the wrong channel).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REFRESH_TOKEN=

# Publishing (private upload → auto-public at Pakistan peak via publishAt)
YT_PRIVACY_STATUS=private
YT_SCHEDULE_PUBLISH=true
ENFORCE_POSTING_GAP=true
MIN_POST_GAP_HOURS=3.0
PUBLISH_TIMEZONE=Asia/Karachi
PUBLISH_SLOTS=10:00,14:00,21:00
YT_MADE_FOR_KIDS=false
CHANNEL_LANGUAGE=ur
YT_CATEGORY_ID=24

# Urdu voice (edge-tts). Voices: asad (male, deep) | uzma (female) | rotate
URDU_VOICE=asad
URDU_TTS_RATE=-12

# Poetry content rules
POETRY_SOURCE=mix          # mix | ghalib | iqbal | mir | original
TARGET_MIN_SECONDS=30
TARGET_MAX_SECONDS=57

# Optional image providers (missing keys are auto-skipped)
AI_HORDE_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
DEEPAI_API_KEY=
MODELSLAB_API_KEY=
REPLICATE_API_TOKEN=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Music (add 3-5 copyright-safe sad tracks to assets/music/ yourself;
# empty MUSIC_TRACK = random rotation; see assets/music/ATTRIBUTION.md)
MUSIC_TRACK=
MUSIC_VOLUME=0.08

VIDEO_HISTORY_PATH=data/video_history.json
UPLOAD_STATE_PATH=data/upload_state.json
VIDEO_TOPIC=
DRY_RUN=false

# --- (Optional) YOUR OWN CLONED VOICE -------------------------------------
# Default engine is free native-Urdu Edge-TTS (asad/uzma). To use your own
# cloned voice via ElevenLabs multilingual (supports Urdu), set ALL of these
# as repo secrets/env and flip the engine:
#   VOICE_ENGINE=elevenlabs
#   ELEVENLABS_API_KEY=...        (elevenlabs.io → Profile → API key)
#   ELEVENLABS_VOICE_ID=...       (your Instant Voice Clone id)
#   ELEVENLABS_MODEL=eleven_multilingual_v2   (optional override)
# If creds are missing the pipeline LOUDLY falls back to Edge-TTS — the
# channel can never break because of voice config.

# --- (FREE) YOUR OWN CLONED VOICE via Qwen3-TTS (zero-shot) ---------------
# Recommended free route. Set repo VARIABLE: VOICE_ENGINE=qwenclone
# Files needed (assistant sets these up from your recording):
#   assets/voice_reference.wav.gpg  (encrypted recording — raw WAV gitignored)
#   assets/voice_reference.txt      (verbatim transcript of that recording)
# Secret needed: VOICE_REF_PASSPHRASE  (decryption key for the .gpg)
# Optional: QWEN_CLONE_MODEL (default Qwen/Qwen3-TTS-12Hz-0.6B-Base)
# Any missing piece -> LOUD fallback to Edge-TTS Asad. Channel never breaks.
